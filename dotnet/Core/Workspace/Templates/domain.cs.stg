			}
		}
$endif$
$\n$
$if(concreteRoleType.RelationType.IsDerived)$
		virtual public IDerivedRoleSignal<$roleSignal_ObjectType(concreteRoleType)$> $if(concreteRoleType.IsMany)$$concreteRoleType.PluralName$$else$$concreteRoleType.SingularName$$endif$
		{
			get
			{
				return this.Strategy.DerivedRole<$roleSignal_ObjectType(concreteRoleType)$>(Meta.$concreteRoleType.Name$);
			}
		}

		virtual public bool Exist$if(concreteRoleType.IsMany)$$concreteRoleType.PluralName$$else$$concreteRoleType.SingularName$$endif$
		{
			get
			{
				return this.$if(concreteRoleType.IsMany)$$concreteRoleType.PluralName$$else$$concreteRoleType.SingularName$$endif$.Exists.Value;
			}
		}
$elseif(concreteRoleType.ObjectType.IsUnit)$
		virtual public IRoleSignal<$concreteRoleType_ObjectType(concreteRoleType)$> $concreteRoleType.SingularName$
		{
			get
			{
				return this.Strategy.ScalarRole<$concreteRoleType_ObjectType(concreteRoleType)$>(Meta.$concreteRoleType.Name$);
			}
		}

		virtual public bool Exist$concreteRoleType.SingularName$
		{
			get
			{
				return this.$concreteRoleType.SingularName$.Exists.Value;
			}
		}

		virtual public void Remove$concreteRoleType.SingularName$()
		{
			this.Strategy.ScalarRole(Meta.$concreteRoleType.Name$).Set(null);
		}
$else$
$if(concreteRoleType.IsMany)$
		virtual public ICompositesRoleSignal<$concreteRoleType_ObjectType(concreteRoleType)$> $concreteRoleType.PluralName$
